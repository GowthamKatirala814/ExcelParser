# Copy this file to backend/.env and fill in real values.
# backend/.env is git-ignored - never commit real secrets.

# --- Gemini API key(s) ---
# One key is enough to run the app. Add more to enable automatic rotation:
# if a key hits its quota/rate limit, the app automatically retries the same
# request with the next key instead of failing the sheet - no code changes
# needed, just more lines here. Any combination of the three forms below is
# fine; they're all merged together (duplicates are dropped).

GEMINI_API_KEY=

# Optional: additional keys, either as a comma-separated list...
# GEMINI_API_KEYS=key-two,key-three

# ...or numbered, one per line (any count):
# GEMINI_API_KEY_1=
# GEMINI_API_KEY_2=
# GEMINI_API_KEY_3=

# Optional overrides (defaults shown):
# LLM_PROVIDER=gemini
# GEMINI_MODEL=gemini-flash-latest
# GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
# GEMINI_KEY_COOLDOWN_SECONDS=60
# LLM_MAX_INPUT_BYTES=15000000

# Note: "gemini-2.5-flash" returns HTTP 404 ("no longer available to new
# users") on some API keys/projects even though it's in the model catalog -
# this is a per-project rollout restriction, not a quota or key problem.
# gemini-flash-latest is a stable alias that doesn't hit that restriction.
